{
  "name": "@fynns/ui-design-core",
  "version": "0.1.0",
  "description": "Fynn's shared dark-teal UI design system: canonical --fynns-* design tokens plus self-developed React primitives (no radix, no sonner). Consumed as source via git submodule + path alias @fynns/ui.",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme.css": "./src/theme/theme.css",
    "./styles.css": "./src/styles.css",
    "./tokens": "./src/theme/tokens.ts",
    "./scrollbar": "./src/theme/scrollbar.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "gen:theme": "node scripts/gen-theme.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "gallery": "vite --config examples/gallery/vite.config.ts",
    "gallery:build": "vite build --config examples/gallery/vite.config.ts"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.21.0",
    "vite": "^6.0.11"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Fynn7/fynns_ui_design_core.git"
  }
}
